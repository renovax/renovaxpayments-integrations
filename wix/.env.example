# --- RENOVAX merchant credentials ---
RENOVAX_API_BASE=https://payments.renovax.net
RENOVAX_BEARER_TOKEN=
RENOVAX_WEBHOOK_SECRET=

# --- Wix Payment Provider SPI ---
# App ID assigned by Wix Dev Center when you create the Payment Provider app.
WIX_APP_ID=
# Public key used by Wix to sign their requests (download from Dev Center).
WIX_PUBLIC_KEY=

# --- Server ---
PORT=3000
INVOICE_TTL_MINUTES=15
