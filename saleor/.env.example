# Public HTTPS URL where this service is reachable. Saleor and RENOVAX
# both call into us via this URL; Saleor also embeds /configuration
# inside its Dashboard via iframe.
APP_URL=https://renovax-saleor.example.com

# HTTP port to bind.
PORT=3000

# Default invoice expiration. The merchant can override per-tenant.
INVOICE_TTL_MINUTES=30

# App Persistence Layer.
#   file  -> .apl.json + .renovax-config.json on disk (good for single-instance dev).
#   redis -> share the project Redis instance with prefixes  saleor:apl:* / saleor:cfg:*.
APL=file
# REDIS_URL=redis://default:password@redis:6379/0

# Optional explicit paths when APL=file.
# APL_FILE=./.apl.json
# CONFIG_FILE=./.renovax-config.json

# IMPORTANT: RENOVAX bearer token and webhook secret are NOT set here.
# Each Saleor tenant configures them from the Dashboard configuration
# panel, and they are persisted per-tenant in the APL backend.
